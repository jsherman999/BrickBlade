# Rebrickable — https://rebrickable.com/users/profile/ (Settings → API)
REBRICKABLE_KEY=

# Brickset — https://brickset.com/tools/webservices/requestkey
BRICKSET_KEY=
# Optional: only needed for user-collection endpoints; leave blank for catalog-only
BRICKSET_USERNAME=
BRICKSET_PASSWORD=

# BrickLink — Account → API Keys (all four are permanent static tokens)
BL_CONSUMER_KEY=
BL_CONSUMER_SECRET=
BL_TOKEN=
BL_TOKEN_SECRET=

# BrickBlade server
BRICKBLADE_BEARER_TOKEN=change-me-to-a-long-random-string
BRICKBLADE_DB_URL=sqlite:///./var/brickblade.db
BRICKBLADE_DATA_DIR=./var
BRICKBLADE_PRICE_TTL_HOURS=48
BRICKBLADE_LOG_LEVEL=INFO
